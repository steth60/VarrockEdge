# VarrokEdge environment

# Web server bind address. On the appliance: 10.0.0.2 (private LAN only).
# On a dev box, leave empty to bind 127.0.0.1.
VE_BIND_HOST=10.0.0.2

# HTTP listen port (HTTPS termination is expected upstream or via SSH tunnel)
VE_PORT=8080

# Path to SQLite DB
VE_DB_PATH=/var/lib/varrok-edge/varrok-edge.db

# Path to runtime config dir (dnsmasq drop-ins, wg0.conf, iptables rules)
VE_CONFIG_DIR=/etc/varrok-edge

# Initial admin password — used by db:seed on first install. install.sh
# generates a random one; the seeded admin must change it on first sign-in.
# Set a strong value here only for manual/dev seeding — never commit a real one.
VE_ADMIN_PASSWORD=

# Session secret — 32+ random bytes, e.g. `openssl rand -base64 32`.
# REQUIRED on Linux (the server refuses to start without it); install.sh
# generates one automatically. Never commit a real value.
VE_SESSION_SECRET=

# Public WAN interface (used by iptables, exempt from bind)
VE_WAN_IFACE=eth0

# Private LAN interface (used by dnsmasq + bind)
VE_LAN_IFACE=eth1

# Log level (trace, debug, info, warn, error)
VE_LOG_LEVEL=info
